# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
APP_NAME=PioneerPath
APP_ENV=production
APP_KEY=
APP_URL=https://api.your-pioneerpath-domain.com
PIONEER_FRONTEND_URL=https://app.your-pioneerpath-domain.com
# Must be false in all non-local environments
APP_DEBUG=false

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US
APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12
PIONEER_CORS_ALLOWED_ORIGINS=https://app.your-pioneerpath-domain.com
PIONEER_SHOW_MOCK_DATA=true
PIONEER_MOCK_INDICATOR_LABEL=Sample

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=pioneerpath
DB_USERNAME=your-mysql-username-here
DB_PASSWORD=your-mysql-password-here
DB_CHARSET=utf8mb4
DB_COLLATION=utf8mb4_unicode_ci

# -----------------------------------------------------------------------------
# Cache and Queue
# -----------------------------------------------------------------------------
CACHE_DRIVER=redis
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE=default

# -----------------------------------------------------------------------------
# GeoTab
# -----------------------------------------------------------------------------
GEOTAB_DATABASE=your-geotab-database-here
GEOTAB_USERNAME=your-geotab-service-account-here
GEOTAB_PASSWORD=your-geotab-password-here
GEOTAB_SERVER=my.geotab.com
GEOTAB_DEFAULT_GROUP_ID=
GEOTAB_FEED_DEFAULT_SEED_DAYS=30
GEOTAB_RETRY_BASE_MS=250
GEOTAB_HTTP_FEED_SYNC=false

# -----------------------------------------------------------------------------
# Google Maps
# -----------------------------------------------------------------------------
GOOGLE_MAPS_BROWSER_KEY=
GOOGLE_MAPS_SERVER_KEY=
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_ENRICHMENT_ENABLED=false
GOOGLE_MAPS_DEPOT_LATITUDE=
GOOGLE_MAPS_DEPOT_LONGITUDE=

# -----------------------------------------------------------------------------
# Push
# -----------------------------------------------------------------------------
VAPID_PUBLIC_KEY=your-vapid-public-key-here
VAPID_PRIVATE_KEY=your-vapid-private-key-here
VAPID_SUBJECT=mailto:admin@yourcompany.com
FIREBASE_CREDENTIALS=
FIREBASE_PROJECT_ID=

# -----------------------------------------------------------------------------
# Mail
# -----------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=smtp.your-mail-provider.com
MAIL_PORT=587
MAIL_USERNAME=your-mail-username-here
MAIL_PASSWORD=your-mail-password-here
MAIL_SCHEME=tls
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@yourcompany.com
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info
LOG_DAILY_DAYS=14
LOG_GEOTAB_LEVEL=info
LOG_WRITE_BACK_LEVEL=info
LOG_AUTH_LEVEL=info
LOG_BILLING_LEVEL=info
LOG_NOTIFICATIONS_LEVEL=info
LOG_BACKUP_LEVEL=info
LOG_INTEGRITY_LEVEL=info
LOG_ERROR_LEVEL=warning
SENTRY_LARAVEL_DSN=

# -----------------------------------------------------------------------------
# SSE
# -----------------------------------------------------------------------------
PIONEER_SSE_ENABLED=true

# -----------------------------------------------------------------------------
# Backups
# -----------------------------------------------------------------------------
PIONEER_BACKUP_PATH=/mnt/pioneerpath-backups/mysql
PIONEER_BACKUP_PATTERNS=*.sql,*.sql.gz,*.dump,*.backup,*.bak
PIONEER_BACKUP_MAX_AGE_HOURS=25

# -----------------------------------------------------------------------------
# Frontend Build Helpers
# -----------------------------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
